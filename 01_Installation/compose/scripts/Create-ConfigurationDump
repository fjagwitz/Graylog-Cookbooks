#!/bin/bash
#
# Usage: 
# Create-ConfigurationDump

sudo date >/dev/null

GRAYLOG_PATH="/opt/graylog"
DUMP_FOLDER="configuration_dump"
BACKUP_FOLDER="$(date "+%Y-%m-%d_%H-%M-%S")_GRAYLOG_STACK_BACKUP"
CONFIGURATION_DUMP_FOLDER="$(date "+%Y-%m-%d_%H-%M-%S")_GRAYLOG_CONFIGURATION_DUMP"

sudo mkdir ${GRAYLOG_PATH}/${DUMP_FOLDER}/${BACKUP_FOLDER}
sudo cp ${GRAYLOG_PATH}/*.yaml ${GRAYLOG_PATH}/${DUMP_FOLDER}/${BACKUP_FOLDER}
sudo cp ${GRAYLOG_PATH}/*.env ${GRAYLOG_PATH}/${DUMP_FOLDER}/${BACKUP_FOLDER}
sudo cp ${GRAYLOG_PATH}/*.txt ${GRAYLOG_PATH}/${DUMP_FOLDER}/${BACKUP_FOLDER}

sudo tar -czf "${GRAYLOG_PATH}/${DUMP_FOLDER}/${BACKUP_FOLDER}.tar.gz" "${GRAYLOG_PATH}/${DUMP_FOLDER}/${BACKUP_FOLDER}" 2>/dev/null

sudo rm -rf "${GRAYLOG_PATH}/${DUMP_FOLDER}/${BACKUP_FOLDER}"

sudo docker compose -f ${GRAYLOG_PATH}/docker-compose.yaml exec mongodb1 mongodump --host=localhost --port=27017 --out "/${DUMP_FOLDER}/${CONFIGURATION_DUMP_FOLDER}" --quiet
sudo tar -czf "${GRAYLOG_PATH}/${DUMP_FOLDER}/${CONFIGURATION_DUMP_FOLDER}.tar.gz" "${GRAYLOG_PATH}/${DUMP_FOLDER}/${CONFIGURATION_DUMP_FOLDER}" 2>/dev/null

sudo rm -rf "${GRAYLOG_PATH}/${DUMP_FOLDER}/${CONFIGURATION_DUMP_FOLDER}"

CONFIGURATION_DUMP_FOLDER_SIZE=$(du -h "${GRAYLOG_PATH}/${DUMP_FOLDER}/${CONFIGURATION_DUMP_FOLDER}.tar.gz" | cut -f1)

if [[ ${USER} == "" ]]
then
  USER="GRAYLOG SYSTEM"
fi

echo "[INFO] - GRAYLOG CONFIGURATION BACKUP (SIZE: ${CONFIGURATION_DUMP_FOLDER_SIZE}) SUCCESSFULLY CREATED BY ${USER^^}" 
echo "[INFO] - GRAYLOG CONFIGURATION BACKUP (SIZE: ${CONFIGURATION_DUMP_FOLDER_SIZE}) SUCCESSFULLY CREATED BY ${USER^^}" | logger -p user.info -e -t GRAYLOG-HELPER

NUMBER_OF_BACKUPS=$(ls -l ${GRAYLOG_PATH}/${DUMP_FOLDER}/ | grep -i dump | wc -l)

while [ ${NUMBER_OF_BACKUPS} -gt 14 ]
do
  
  FILE_TO_DELETE=$(ls ${GRAYLOG_PATH}/${DUMP_FOLDER}/ | grep -i dump | sort | head -n1)
  sudo rm ${GRAYLOG_PATH}/${DUMP_FOLDER}/${FILE_TO_DELETE}
  NUMBER_OF_BACKUPS=$((${NUMBER_OF_BACKUPS}-1))
  
  echo "[INFO] - GRAYLOG CONFIGURATION BACKUP ${FILE_TO_DELETE} DELETED BY ${USER^^}, ${NUMBER_OF_BACKUPS} BACKUPS REMAINING"
  echo "[INFO] - GRAYLOG CONFIGURATION BACKUP ${FILE_TO_DELETE} DELETED BY ${USER^^}, ${NUMBER_OF_BACKUPS} BACKUPS REMAINING" | logger -p user.info -e -t GRAYLOG-HELPER

done
